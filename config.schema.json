{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/seunghunbae-3svs/solo-cto-agent/config.schema.json",
  "title": "solo-cto-agent configuration",
  "description": "User configuration for solo-cto-agent. All fields are optional.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference (ignored by the tool)"
    },
    "models": {
      "type": "object",
      "description": "Override default model names for each provider.",
      "properties": {
        "claude": { "type": "string", "description": "Default Claude model (e.g. claude-sonnet-4-20250514)" },
        "codex": { "type": "string", "description": "Default Codex model (e.g. codex-mini-latest)" },
        "openai": { "type": "string", "description": "Default OpenAI model (e.g. gpt-4o)" }
      },
      "additionalProperties": false
    },
    "tierModels": {
      "type": "object",
      "description": "Override tier-specific model assignments.",
      "properties": {
        "claude": {
          "type": "object",
          "properties": {
            "maker": { "type": "string" },
            "builder": { "type": "string" },
            "cto": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "providers": {
      "type": "object",
      "description": "API endpoint overrides for alternative LLM providers.",
      "properties": {
        "anthropicBase": {
          "type": "string",
          "description": "Anthropic API hostname (e.g. api.anthropic.com, localhost:11434)",
          "pattern": "^[^/]+$"
        },
        "openaiBase": {
          "type": "string",
          "description": "OpenAI-compatible API hostname (e.g. api.openai.com, localhost:1234)",
          "pattern": "^[^/]+$"
        }
      },
      "additionalProperties": false
    },
    "diff": {
      "type": "object",
      "description": "Diff processing settings.",
      "properties": {
        "maxChunkBytes": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 1048576,
          "default": 50000,
          "description": "Maximum diff size in bytes before truncation (1KB-1MB)"
        }
      },
      "additionalProperties": false
    },
    "routines": {
      "type": "object",
      "description": "Claude Code Routines — cloud-based scheduled/triggered reviews (CTO tier). Cost: standard token rates. Daily caps: Pro=5, Max=15, Team/Enterprise=25.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Routines integration"
        },
        "triggerId": {
          "type": "string",
          "pattern": "^trig_",
          "description": "Routine trigger ID from Claude Code (e.g. trig_01ABC...)"
        },
        "schedules": {
          "type": "array",
          "description": "Custom schedule entries (name, cron, triggerId, text)",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "cron": { "type": "string", "description": "Cron expression (e.g. '0 2 * * *' for 2am daily)" },
              "triggerId": { "type": "string" },
              "text": { "type": "string", "description": "Context text sent with the /fire request" }
            },
            "required": ["name", "triggerId"]
          }
        }
      },
      "additionalProperties": false
    },
    "managedAgents": {
      "type": "object",
      "description": "Claude Managed Agents — deep review with sandboxed code execution (CTO tier). Cost: standard token rates + $0.08/session-hour active runtime.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Managed Agents deep-review"
        },
        "model": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Model for Managed Agent sessions (claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001)"
        },
        "sessionTimeoutMs": {
          "type": "integer",
          "minimum": 30000,
          "maximum": 600000,
          "default": 300000,
          "description": "Max session duration in ms (30s-10min, default 5min)"
        }
      },
      "additionalProperties": false
    }
  }
}

# Required — core Claude agent
ANTHROPIC_API_KEY=

# Optional — enables dual-agent cross-review (CTO tier)
OPENAI_API_KEY=

# Required for orchestrator repo operations
GITHUB_TOKEN=
ORCHESTRATOR_PAT=

# Optional integrations
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=

# Telegram bot: CTO-level command surface (/status, /list, /rework, /approve, /do, /digest, /merge)
# Admin-only actions (/merge + MERGE button) are limited to these chat IDs.
TELEGRAM_ADMIN_CHAT_IDS=
# Comma-separated "owner/repo" slugs. Falls back to PRODUCT_REPOS if unset.
TRACKED_REPOS=
PRODUCT_REPOS=
# GitHub owner + orchestrator repo (used by /rework + REWORK button to dispatch events)
GITHUB_OWNER=
ORCH_REPO=
ORCH_REPO_SLUG=

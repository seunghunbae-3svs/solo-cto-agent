# Required — core Claude agent
ANTHROPIC_API_KEY=

# Optional — enables dual-agent cross-review (CTO tier)
OPENAI_API_KEY=

# Required for orchestrator repo operations
GITHUB_TOKEN=
ORCHESTRATOR_PAT=

# Optional integrations
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RESEND_API_KEY=

# Optional — mirror of Telegram output (visual-check screenshots,
# auto-diagnose reports, PR merge notifications). Post a webhook URL
# from your Discord server settings.
DISCORD_WEBHOOK_URL=

# Optional — Vercel preview URL resolution for before/after visual reports.
# If set, visual-report.yml shoots screenshots of pre- and post-rework
# preview deployments. If unset, the visual stage silently skips.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# Optional — alternate screenshot provider. Default is playwright (installed
# in the orchestrator workflow). Set to 'browserless' to use Browserless.io
# (free tier: 1000/month), or 'off' to disable the visual stage entirely.
VISUAL_REVIEW_PROVIDER=
BROWSERLESS_API_KEY=

# Telegram bot: CTO-level command surface (/status, /list, /rework, /approve, /do, /digest, /merge)
# Admin-only actions (/merge + MERGE button) are limited to these chat IDs.
TELEGRAM_ADMIN_CHAT_IDS=
# Comma-separated "owner/repo" slugs. Falls back to PRODUCT_REPOS if unset.
TRACKED_REPOS=
PRODUCT_REPOS=
# GitHub owner + orchestrator repo (used by /rework + REWORK button to dispatch events)
GITHUB_OWNER=
ORCH_REPO=
ORCH_REPO_SLUG=

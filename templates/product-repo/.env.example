# === App Config ===
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Auth ===
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# === GitHub Secrets (set in repo Settings → Secrets, NOT in this file) ===
# See SECRETS_SETUP.md for the full list + provisioning guide.
#
# Required:
#   ORCHESTRATOR_PAT        — PAT (repo, workflow scope). Same value as orchestrator repo.
#
# Recommended (Telegram decision cards):
#   TELEGRAM_BOT_TOKEN      — from @BotFather
#   TELEGRAM_CHAT_ID        — chat.id returned by bot's getUpdates
#
# Optional (preview URL auto-capture for Vercel-hosted projects):
#   VERCEL_TOKEN            — vercel.com/account/tokens
#   VERCEL_ORG_ID           — from .vercel/project.json
#   VERCEL_PROJECT_ID       — from .vercel/project.json
#
# Usually NOT needed on product repo (set on orchestrator repo instead):
#   ANTHROPIC_API_KEY       — only if this repo runs its own Claude worker
#   OPENAI_API_KEY          — only if this repo runs its own Codex worker
